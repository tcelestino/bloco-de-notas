<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
     <meta name="title" content="{{ site.title }}" />
    <meta
      name="description"
      content="{{ summary or site.description }}"
    />
    <meta
      name="keywords"
      content="{{ (tags or site.keywords) | join(', ') }}"
    />
    <link href="{{ site.feedPath }}" type="application/rss+xml" rel="alternate" title="{{ site.title }}">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="{% if title %}article{% else %}website{% endif %}" />
    <meta property="og:url" content="{{ site.baseUrl }}{{ page.url }}" />
    <meta property="og:title" content="{{ title or site.title }}" />
    <meta property="og:description" content="{{ summary or site.description }}" />
    <meta property="og:image" content="{{ site.url }}assets/images/og-default.png" />
    <meta property="og:site_name" content="{{ site.title }}" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ title or site.title }}" />
    <meta name="twitter:description" content="{{ summary or site.description }}" />
    <meta name="twitter:image" content="{{ site.url }}assets/images/og-default.png" />

    <link rel="stylesheet" href="/assets/css/main.css" />
    <title>{% if summary %}{{ summary }} - {% endif %}{{ site.title }}</title>

    <script defer src="https://cloud.umami.is/script.js" data-website-id="706bda1c-3aca-440d-b69a-905012ef0900"></script>
  </head>

  <body>
    <header class="top-header">
      <h1><a href="/">Blocos de Notas</a></h1>
      <small>Por Tiago Celestino</small>
      <nav class="nav-links">
        <ul class="nav-pages">
          {% for item in collections.navLinks.pages %}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
        <ul class="nav-social">
          {% for item in collections.navLinks.social %}
            <li class="social-link-{{ item.title | lower }}"><a href="{{ item.url }}"  target="_blank" rel="noopener noreferrer" title="{{ item.linkTitle }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </nav>
    </header>

    <main class="content-page">
      {{ content | safe }}
    </main>

    <footer class="content-footer">
      <small>built with <a href="https://11ty.dev" rel="noopener noreferrer" target="_blank">11ty</a></small>
    </footer>
  </body>
</html>
